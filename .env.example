# ──────────────────────────────────────────────────────────────────
# Sprout — Next.js environment template
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored. NEVER commit real keys.
# ──────────────────────────────────────────────────────────────────

# === Required ===

# OpenRouter — single key for STT, LLM, TTS, embeddings, image gen
# Get one at https://openrouter.ai
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Qdrant Cloud — vector database for the knowledge base
# Get a free 1GB instance at https://cloud.qdrant.io
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=REPLACE_ME

# LiveKit Cloud — real-time voice orchestration
# Get keys at https://livekit.io
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=APIxxxxx_REPLACE_ME
LIVEKIT_API_SECRET=REPLACE_ME
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud

# === Optional ===

# trigger.dev — scheduled weekly nudges. Sprout still works without these.
# Get keys at https://trigger.dev
TRIGGER_API_KEY=tr_pat_REPLACE_ME
TRIGGER_PROJECT_ID=proj_REPLACE_ME

# Web Push (VAPID) — for nudge notifications. Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REPLACE_ME
VAPID_PRIVATE_KEY=REPLACE_ME
NEXT_PUBLIC_VAPID_PUBLIC_KEY=REPLACE_ME

# OpenAI — alternative image generation (GPT-Image fallback). Optional.
OPENAI_API_KEY=sk-proj-REPLACE_ME

# === Local dev ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AGENT_SERVICE_URL=http://localhost:8000
NODE_ENV=development
