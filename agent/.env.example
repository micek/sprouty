# ──────────────────────────────────────────────────────────────────
# Sprouty — Python LiveKit agent environment template
# Copy this file to `agent/.env` and fill in real values.
# `agent/.env` is gitignored. NEVER commit real keys.
#
# The agent runs an all-Mistral audio stack with the LLM via OpenRouter:
#
#   STT  → Voxtral STT via Mistral direct   (sponsor product #1)
#   LLM  → Mistral Small via OpenRouter     (sponsor product #2)
#   TTS  → Voxtral TTS via Mistral direct   (sponsor product #3)
#
# OpenRouter does NOT proxy audio APIs, so STT and TTS both go direct to
# Mistral's own endpoints. The custom VoxtralTTS plugin in voxtral_tts.py
# wraps Mistral's TTS API which isn't OpenAI-compatible.
# ──────────────────────────────────────────────────────────────────

# === Required ===

# Mistral — Voxtral STT and Voxtral TTS both live here.
# Get a key at https://console.mistral.ai
MISTRAL_API_KEY=REPLACE_ME

# OpenRouter — chat completions for Mistral Small (LLM)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# LiveKit Cloud — WebRTC orchestration (same values as the Next.js side)
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=APIxxxxx_REPLACE_ME
LIVEKIT_API_SECRET=REPLACE_ME

# === Optional overrides ===

# Endpoint base URLs — defaults below are correct, override only if you're
# pointing at a self-hosted gateway or a regional mirror.
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Model IDs — defaults below are the sponsor-bonus picks.
MISTRAL_STT_MODEL=voxtral-mini-2507
MISTRAL_LLM_MODEL=mistralai/mistral-small
MISTRAL_TTS_MODEL=voxtral-mini-tts-2603

# Voxtral TTS preset voice. Public docs reference voices like Marie (French
# neutral), Oliver (English excited), Nick (Spanish neutral), plus Margaret,
# Sanchit, Angele, Gustavo, Khyathi, Yassir, Patrick. The exact `voice_id`
# casing isn't fully documented — if `oliver` 400s, try `Oliver`, then list
# voices with: python -m agent.voxtral_tts list-voices
MISTRAL_TTS_VOICE=oliver

# Qdrant Cloud — required for the agent's mid-conversation knowledge-base
# tool (search_knowledge_base). Same cluster the browser ingest writes into.
# If left as REPLACE_ME the tool reports "knowledge base not configured" and
# the rest of the voice flow still works.
QDRANT_URL=https://YOUR-CLUSTER.cloud.qdrant.io
QDRANT_API_KEY=REPLACE_ME
